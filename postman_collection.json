              "mode": "raw",
              "raw": "{\"name\": \"Ayush\", \"email\": \"ayush@test.com\", \"password\": \"123456\", \"currency\": \"INR\"}"
            },
            "url": {
              "raw": "http://localhost:3000/api/users",
              "host": ["localhost"],
              "port": "3000",
              "path": ["api", "users"]
            }
          }
        },
